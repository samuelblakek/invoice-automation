# Streamlit secrets template — copy the relevant keys into your real secrets.
#
# On Streamlit Community Cloud:  Manage app → Settings → Secrets, then paste:
#     app_password = "choose-a-strong-password"
#
# Locally: copy this file to .streamlit/secrets.toml (gitignored) and fill it in.
#
# If `app_password` is absent, the app runs WITHOUT a login gate (fine for local
# development, not recommended for the deployed app).

app_password = "change-me"
